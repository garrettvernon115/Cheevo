# Copy this file to .env and fill in your values

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://cheevo:cheevo@localhost:5432/cheevo

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenXBL — get your key at https://xbl.io
OPENXBL_API_KEY=your_openxbl_api_key_here

# Your Xbox User ID (XUID) — find at xboxgamertag.com or via the OpenXBL profile endpoint
MY_XUID=your_xuid_here

# Anthropic — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Set to true to enable SQLAlchemy query logging
DEBUG=false
